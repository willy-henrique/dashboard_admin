rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 📁 adminmaster: documento "master" (com email/senhaHash) NÃO é legível pelo cliente.
    // Login é feito pela API (backend). Apenas a subcoleção usuarios é legível pelo cliente.
    match /adminmaster/{document} {
      allow read, write: if document != 'master';

      match /usuarios/{usuarioId} {
        allow read, write: if true;
      }
    }

    // 🔓 Restante do banco (desenvolvimento)
    match /{path=**} {
      allow read, write: if request.path != /databases/$(database)/documents/adminmaster/master;
    }
  }
}
